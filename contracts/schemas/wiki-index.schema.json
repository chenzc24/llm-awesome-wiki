{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-awesome-wiki.local/contracts/wiki-index.schema.json",
  "title": "Wiki Index",
  "type": "object",
  "required": ["index_version", "updated", "entries"],
  "properties": {
    "index_version": {
      "type": "string"
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "title", "page_type"],
        "properties": {
          "path": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "page_type": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "source_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
