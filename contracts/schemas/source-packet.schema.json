{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-awesome-wiki.local/contracts/source-packet.schema.json",
  "title": "Source Packet",
  "type": "object",
  "required": ["source_id", "raw_path", "source_kind", "extraction_status", "anchors"],
  "properties": {
    "source_id": {
      "type": "string"
    },
    "raw_path": {
      "type": "string"
    },
    "raw_sha256": {
      "type": "string"
    },
    "source_title": {
      "type": "string"
    },
    "added_at": {
      "type": "string",
      "format": "date"
    },
    "source_kind": {
      "type": "string"
    },
    "inventory_status_at_extraction": {
      "type": "string"
    },
    "extraction_backend": {
      "type": "string"
    },
    "extraction_method": {
      "type": "string"
    },
    "extraction_version": {
      "type": "string"
    },
    "extraction_status": {
      "type": "string",
      "enum": ["complete", "partial", "failed", "manual-review"]
    },
    "modalities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["text", "image", "table", "audio", "video", "code", "data", "other"]
      }
    },
    "generated_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "known_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_required": {
      "type": "boolean"
    },
    "review_reason": {
      "type": "string"
    },
    "derived_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["anchor_id", "label"],
        "properties": {
          "anchor_id": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "content_kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "source_derived": {
            "type": "boolean"
          },
          "generated": {
            "type": "boolean"
          },
          "media_ref": {
            "type": "string"
          },
          "review_required": {
            "type": "boolean"
          },
          "text": {
            "type": "string"
          },
          "modality": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_item_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
