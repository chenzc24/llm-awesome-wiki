{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-awesome-wiki.local/contracts/review-item.schema.json",
  "title": "Review Item",
  "type": "object",
  "required": ["review_item_id", "type", "title", "status", "created"],
  "properties": {
    "review_item_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "contradiction",
        "duplicate",
        "missing-page",
        "confirm",
        "suggestion",
        "unsupported-claim",
        "extraction-gap",
        "generated-evidence",
        "modality-review",
        "omission",
        "weak-coverage"
      ]
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in-review",
        "resolved",
        "dismissed",
        "carried-forward",
        "blocked",
        "stale"
      ]
    },
    "blocking_level": {
      "type": "string",
      "enum": ["blocking", "nonblocking", "informational"]
    },
    "dismissal_reason": {
      "type": "string",
      "enum": [
        "duplicate",
        "out-of-scope",
        "incorrect-reference",
        "superseded",
        "informational-only",
        "no-longer-relevant"
      ]
    },
    "affected_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
