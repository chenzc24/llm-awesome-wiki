{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-awesome-wiki.local/contracts/wiki-page.schema.json",
  "title": "Wiki Page Metadata",
  "type": "object",
  "required": ["type", "title", "sources", "created", "updated"],
  "properties": {
    "type": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_item_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "updated": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": true
}
