{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-awesome-wiki.local/contracts/compare-report.schema.json",
  "title": "Compare Report",
  "type": "object",
  "required": ["report_id", "generated_at", "status", "checks"],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "round_id": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "needs-review"]
    },
    "summary": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "status", "summary"],
        "properties": {
          "check_id": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": ["deterministic", "manual-protocol", "human-review"]
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "needs-review", "not-run", "not-enabled"]
          },
          "summary": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "review_item_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "carried_forward_review_item_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "closure_decision": {
      "type": "string",
      "enum": ["close-pass", "close-with-review", "do-not-close"]
    }
  },
  "additionalProperties": true
}
