{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-awesome-wiki.local/contracts/source-inventory.schema.json",
  "title": "Source Inventory",
  "type": "object",
  "required": ["inventory_version", "generated_at", "sources"],
  "properties": {
    "inventory_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "workspace_root": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "path", "source_kind", "status"],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "added_at": {
            "type": "string",
            "format": "date"
          },
          "changed_at": {
            "type": "string",
            "format": "date"
          },
          "source_kind": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["new", "processed", "changed", "ignored", "failed"]
          },
          "packet_path": {
            "type": "string"
          },
          "review_item_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
